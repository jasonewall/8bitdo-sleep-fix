[Unit]
Description=8BitDo Automated Unbind and Sleep
Before=sleep.target
StopWhenUnneeded=yes

[Service]
Type=oneshot
RemainAfterExit=yes
EnvironmentFile=-/etc/default/8bitdo-sleep-fix

ExecStart=/etc/scripts/8bitdo-sleep-fix sleep

ExecStop=/etc/scripts/8bitdo-sleep-fix wake

SuccessExitStatus=0 1

[Install]
RequiredBy=sleep.target
